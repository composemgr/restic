# Restic REST Server — environment variable reference
# Copy relevant lines to a .env file alongside docker-compose.yaml
# Create /data/.htpasswd with: htpasswd -B -c /path/to/.htpasswd <username>

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=${HOSTNAME}

# Path to .htpasswd file inside the container
PASSWORD_FILE=/data/.htpasswd

# Extra flags passed to rest-server (e.g. --prometheus --private-repos)
OPTIONS=
